---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatsGrid from '../components/StatsGrid.astro';
import EntryCard from '../components/EntryCard.astro';
import literature from '../data/literature.json';
import taxonomy from '../data/taxonomy.json';

const entries = literature.entries;
const totalEntries = entries.length;
const reviewedCount = entries.filter(e => e.reviewed).length;
const typeCount = new Set(entries.map(e => e.type)).size;
const categoryCount = taxonomy.domains.reduce((sum, d) => sum + d.categories.length, 0);
const yearRange = `${Math.min(...entries.map(e => e.year))}-${Math.max(...entries.map(e => e.year))}`;

const stats = [
  { label: 'Total Resources', value: totalEntries },
  { label: 'Reviewed', value: reviewedCount },
  { label: 'Categories', value: categoryCount },
  { label: 'Resource Types', value: typeCount },
];

// Recent and most cited
const recentEntries = [...entries].sort((a, b) => b.year - a.year || (b.citation_count || 0) - (a.citation_count || 0)).slice(0, 5);
const topCited = [...entries].filter(e => e.citation_count).sort((a, b) => (b.citation_count || 0) - (a.citation_count || 0)).slice(0, 5);

// Category distribution
const catCounts: Record<string, number> = {};
entries.forEach(e => e.categories.forEach(c => { catCounts[c] = (catCounts[c] || 0) + 1; }));
const topCategories = Object.entries(catCounts).sort((a, b) => b[1] - a[1]).slice(0, 10);

const base = import.meta.env.BASE_URL;

// Framework coverage counts
const frameworkDefs = [
  { key: 'owasp_llm_top10', label: 'OWASP LLM Top 10' },
  { key: 'owasp_agentic_top10', label: 'OWASP Agentic Top 10' },
  { key: 'mitre_atlas', label: 'MITRE ATLAS' },
  { key: 'nist_ai_rmf', label: 'NIST AI RMF' },
  { key: 'iso_42001', label: 'ISO/IEC 42001' },
];

const frameworkCounts = frameworkDefs.map(fw => {
  const count = entries.filter(e => {
    const mappings = (e as any).framework_mappings;
    return mappings && mappings[fw.key] && mappings[fw.key].length > 0;
  }).length;
  return { ...fw, count };
});
---

<BaseLayout title="Home">
  <div class="space-y-10">
    <!-- Hero -->
    <div class="text-center py-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">GenAI Security Literature Review</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-6">
        A comprehensive, community-driven, auto-updating database of GenAI and LLM security research, standards, tools, and resources.
      </p>
      <div class="flex justify-center gap-4">
        <a href={`${base}search/`} class="bg-primary-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-700 no-underline transition-colors">
          Search Resources
        </a>
        <a href={`${base}browse/`} class="bg-white text-primary-600 px-6 py-3 rounded-lg font-medium border border-primary-600 hover:bg-primary-50 no-underline transition-colors">
          Browse Categories
        </a>
      </div>
    </div>

    <!-- Stats -->
    <StatsGrid stats={stats} />

    <!-- Two columns: Recent + Top Cited -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Recent Additions</h2>
        <div class="space-y-4">
          {recentEntries.map(entry => <EntryCard entry={entry} />)}
        </div>
      </div>
      <div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Most Cited</h2>
        <div class="space-y-4">
          {topCited.map(entry => <EntryCard entry={entry} />)}
        </div>
      </div>
    </div>

    <!-- Top categories -->
    <div>
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Top Categories</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        {topCategories.map(([cat, count]) => (
          <a href={`${base}browse/${cat}/`} class="card text-center no-underline hover:border-primary-300">
            <div class="text-2xl font-bold text-primary-600">{count}</div>
            <div class="text-sm text-gray-600 mt-1">{cat.replace(/-/g, ' ')}</div>
          </a>
        ))}
      </div>
    </div>

    <!-- Framework coverage -->
    <div class="card">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Framework Coverage</h2>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4 text-center">
        {frameworkCounts.map(fw => (
          <a href={`${base}frameworks/`} class="no-underline">
            <div class="text-2xl font-bold text-primary-600">{fw.count}</div>
            <div class="text-xs text-gray-600">{fw.label}</div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
