---
import BaseLayout from '../layouts/BaseLayout.astro';
import FrameworkBadge from '../components/FrameworkBadge.astro';
import literature from '../data/literature.json';
import frameworksData from '../data/frameworks.json';

const entries = literature.entries;
const base = import.meta.env.BASE_URL;

// Build mapping: framework -> entry ID -> entries
const frameworkEntries: Record<string, Record<string, typeof entries>> = {};

frameworksData.frameworks.forEach(fw => {
  const entryMap: Record<string, typeof entries> = {};
  fw.entries.forEach(fwEntry => {
    const matching = entries.filter(e => {
      const mappings = (e as any).framework_mappings;
      return mappings && mappings[fw.id] && mappings[fw.id].includes(fwEntry.id);
    });
    if (matching.length > 0) {
      entryMap[fwEntry.id] = matching;
    }
  });
  frameworkEntries[fw.id] = entryMap;
});
---

<BaseLayout title="Framework Mappings">
  <div>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Framework Mappings</h1>
    <p class="text-gray-600 mb-8">
      Browse resources mapped to security frameworks: OWASP, NIST, MITRE ATLAS, and ISO/IEC 42001.
    </p>

    <div class="space-y-8">
      {frameworksData.frameworks.map(fw => (
        <div class="card" id={fw.id}>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-gray-900">{fw.name}</h2>
            <a href={fw.url} target="_blank" rel="noopener noreferrer" class="text-sm text-primary-600 hover:underline">
              Official site
            </a>
          </div>

          <div class="space-y-4">
            {fw.entries.map(fwEntry => {
              const matchingEntries = frameworkEntries[fw.id]?.[fwEntry.id] || [];
              return (
                <div class="border-l-4 border-primary-200 pl-4">
                  <div class="flex items-center gap-2 mb-1">
                    <FrameworkBadge framework={fw.id} id={fwEntry.id} />
                    <span class="font-medium text-gray-900">{fwEntry.name}</span>
                    <span class="text-xs text-gray-500">({matchingEntries.length} resources)</span>
                  </div>
                  {'description' in fwEntry && fwEntry.description && (
                    <p class="text-sm text-gray-500 mb-2">{fwEntry.description}</p>
                  )}
                  {matchingEntries.length > 0 && (
                    <ul class="space-y-1">
                      {matchingEntries.slice(0, 5).map(entry => (
                        <li class="text-sm">
                          <a href={`${base}entry/${entry.id}/`} class="hover:underline">{entry.title}</a>
                          <span class="text-gray-400"> ({entry.year})</span>
                        </li>
                      ))}
                      {matchingEntries.length > 5 && (
                        <li class="text-sm text-gray-500">+ {matchingEntries.length - 5} more</li>
                      )}
                    </ul>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
