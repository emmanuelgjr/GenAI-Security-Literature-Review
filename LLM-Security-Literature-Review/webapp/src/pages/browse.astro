---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryTree from '../components/CategoryTree.astro';
import EntryCard from '../components/EntryCard.astro';
import literature from '../data/literature.json';
import taxonomy from '../data/taxonomy.json';

const entries = literature.entries;

// Count entries per category
const entryCounts: Record<string, number> = {};
entries.forEach(e => {
  e.categories.forEach(c => {
    entryCounts[c] = (entryCounts[c] || 0) + 1;
  });
});

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Browse by Category">
  <div>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Browse by Category</h1>
    <p class="text-gray-600 mb-8">
      Explore {entries.length} resources across {taxonomy.domains.length} domains and {taxonomy.domains.reduce((s, d) => s + d.categories.length, 0)} categories.
    </p>
    <CategoryTree domains={taxonomy.domains} entryCounts={entryCounts} />
  </div>
</BaseLayout>

<script>
  // Handle ?category= query parameter to show filtered results
  const params = new URLSearchParams(window.location.search);
  const category = params.get('category');
  if (category) {
    document.title = `${category.replace(/-/g, ' ')} | Browse | LLM Security Literature Review`;
  }
</script>
